<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Controller_SelectedScaffolderID>MvcControllerWithActionsScaffolder</Controller_SelectedScaffolderID>
    <Controller_SelectedScaffolderCategoryPath>root/Common/MVC/Controller</Controller_SelectedScaffolderCategoryPath>
    <View_SelectedScaffolderID>RazorViewScaffolder</View_SelectedScaffolderID>
    <View_SelectedScaffolderCategoryPath>root/Common/MVC/View</View_SelectedScaffolderCategoryPath>
    <WebStackScaffolding_ViewDialogWidth>650</WebStackScaffolding_ViewDialogWidth>
    <WebStackScaffolding_IsLayoutPageSelected>True</WebStackScaffolding_IsLayoutPageSelected>
    <WebStackScaffolding_IsPartialViewSelected>False</WebStackScaffolding_IsPartialViewSelected>
    <WebStackScaffolding_IsReferencingScriptLibrariesSelected>False</WebStackScaffolding_IsReferencingScriptLibrariesSelected>
    <WebStackScaffolding_DbContextTypeFullName>Frontend.Models.Data.IOTSMSDBContext.IOTSMSDBContext</WebStackScaffolding_DbContextTypeFullName>
    <ShowAllFiles>false</ShowAllFiles>
    <WebStackScaffolding_LayoutPageFile>~/Views/Shared/_AdminDashboardLayout.cshtml</WebStackScaffolding_LayoutPageFile>
  </PropertyGroup>
  <ItemGroup>
    <Compile Update="Reports\ListOfDevicesByOfficer.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Reports\ListOfDevicesReport.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Reports\ListOfFarmers.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Reports\ListOfFarms.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Reports\RegisteredFarmersByOfficerReport.cs">
      <SubType>Component</SubType>
    </Compile>
    <Compile Update="Reports\SoilDataReport.cs">
      <SubType>Component</SubType>
    </Compile>
  </ItemGroup>
</Project>